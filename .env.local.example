# .env.local.example — copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# ---------------------------------------------------------------------------
# Spotify Developer App
# Create an app at https://developer.spotify.com/dashboard
# Add the redirect URIs listed below to your app's "Redirect URIs" settings.
# ---------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# ---------------------------------------------------------------------------
# Database
# Local Postgres: postgresql://user:password@localhost/spotify_skip_tracker
# Neon (managed): postgresql://user:pass@host/db?sslmode=require
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost/spotify_skip_tracker

# ---------------------------------------------------------------------------
# Security
# Generate TOKEN_ENCRYPTION_KEY with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_KEY can be any stable random string. A new value on every restart
# invalidates all active sessions.
# ---------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=your_fernet_key_here
SECRET_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# OAuth redirect URIs
#
# Two separate OAuth flows exist:
#
#   1. CLI setup (python3 -m spotify_skip_tracker setup)
#      Uses a temporary local server on port 8888.
#      Register this in your Spotify app:  http://127.0.0.1:8888/callback
#      No env var needed — this is hardcoded in the CLI.
#
#   2. Web login (/api/auth/login in the browser)
#      Uses the Flask server on port 5000.
#      Register this in your Spotify app:  http://127.0.0.1:5000/api/auth/callback
#      Set REDIRECT_URI_WEB to that same URL below.
#
# For local development, register BOTH URIs in your Spotify Developer App.
# ---------------------------------------------------------------------------
REDIRECT_URI_WEB=http://127.0.0.1:5000/api/auth/callback

# URL of the frontend — used for CORS and post-login redirect.
# Vite dev server: http://localhost:5173
# Flask serving the built frontend: http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Set to true to enable the /api/auth/demo endpoint (serves static demo data
# without requiring a real Spotify account).
# DEMO_MODE=false

# Your Spotify user ID. Only needed for the legacy data backfill command.
# SPOTIFY_USER_ID=your_spotify_user_id
